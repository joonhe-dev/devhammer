{
  "name": "devhammer",
  "version": "0.1.0",
  "description": "🔨 A local-first CLI toolset for TypeScript full-stack developers",
  "bin": { "devhammer": "./dist/index.js" },
  "type": "module",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["cli", "developer-tools", "typescript", "config", "api", "scaffold", "env"],
  "author": "Joonhe <hello@joonhe.dev>",
  "license": "MIT",
  "repository": "github:joonhe-dev/devhammer",
  "engines": { "node": ">=18.0.0" },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3",
    "eslint": "^9",
    "prettier": "^3",
    "tsup": "^8",
    "typescript": "^5.8",
    "typescript-eslint": "^8",
    "vitest": "^3"
  },
  "dependencies": {
    "commander": "^13"
  }
}
